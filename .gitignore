# ==========================================
# Chezmoi Internal Files (Crucial)
# ==========================================
# Ignore Chezmoi's own temporary state, cache, and lock files
.chezmoibase*
.chezmoidata*
.chezmoilock
.chezmoi.toml.cache

# ==========================================
# Secrets and Sensitive Data
# ==========================================
# Never commit private keys, tokens, or environment files in plaintext
*.pem
*.key
*.pub
*id_rsa
*id_ed25519
.env
.env.*
secrets/

# ==========================================
# Operating System Junk
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.fuse_hidden*

# ==========================================
# Editors and IDEs
# ==========================================
# Vim / Emacs
.*.swp
.*.swo
\#*\#
.#*

# VS Code / VSCodium
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/extensions.json

# IntelliJ IDEA (Since you use it for merging)
.idea/
*.iml
*.iws

# ==========================================
# Package Managers & Caching
# ==========================================
# If you run scripts, linters, or hooks inside your dotfiles
node_modules/
.npm/
.yarn/
__pycache__/
*.pyc
.pytest_cache/
