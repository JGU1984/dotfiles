# IDE files (prevent IntelliJ/PyCharm/VSCode files from being tracked)
*.iml
.idea/
.vscode/
*.swp
*.swo
*~
# OS-specific files
.DS_Store
Thumbs.db
desktop.ini
# Build artifacts and caches
node_modules/
*.pyc
__pycache__/
.cache/
# Scripts directory - for version control only, not deployed
scripts/
# README is for documentation only, not deployed
README.md
# Temporary files
*.tmp
*.log
*.bak
# Files that should only exist in chezmoi source, not deployed to this machine
# On your main machine (lenovoLinux), don't deploy gnome-settings.ini
# It will be deployed on new installations with different hostnames
# The run_onchange script will handle the missing file gracefully
{{ if eq .chezmoi.hostname "lenovoLinux" }}
.config/dconf/gnome-settings.ini
{{ end }}
