# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:/usr/local/bin:$PATH

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"


# Source Antigen
source ~/antigen.zsh

## Use Antigen to load stuff

# Use oh-my-zsh
antigen use oh-my-zsh

## Use some plugins

# Source Alias
antigen bundle git
antigen bundle mvn
antigen bundle command-not-found
antigen bundle zsh-users/zsh-autosuggestions
antigen bundle fzf
antigen bundle fd
antigen bundle agkozak/zsh-z

#Syntax highlightning bundle.
antigen bundle zsh-users/zsh-syntax-highlighting

## Load a custom Theme
#antigen theme robbyrussell
#antigen theme eastwood
#antigen theme gnzh
antigen theme agnoster
#antigen theme romkatv/powerlevel10k

##My Changes
setopt EXTENDED_GLOB
for file in ~/.zsh_local/*.zsh; do
	if [[ -e $file ]]; then
		. $file
	fi
done
##

##Go test colour formating script
go_test() {
  go test $* | sed ''/PASS/s//$(printf "\033[32mPASS\033[0m")/'' | sed ''/SKIP/s//$(printf "\033[34mSKIP\033[0m")/'' | sed ''/FAIL/s//$(printf "\033[31mFAIL\033[0m")/'' | sed ''/FAIL/s//$(printf "\033[31mFAIL\033[0m")/'' | GREP_COLOR="01;33" egrep --color=always '\s*[a-zA-Z0-9\-_.]+[:][0-9]+[:]|^'
}

#Commit Antigen Configuration
antigen apply

source ~/.zsh_local/aliases.zsh

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# Setting Java Path
export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
export PATH=$PATH:$JAVA_HOME/bin

## Setting Go Path
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin


export PATH="~/bin:$PATH:$HOME/.local/bin:$PATH"

# opencode
export PATH={{ .chezmoi.homeDir }}/.opencode/bin:$PATH

export VISUAL=nano
export EDITOR="$VISUAL"
source {{ .chezmoi.homeDir }}/.config/broot/launcher/bash/br

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

